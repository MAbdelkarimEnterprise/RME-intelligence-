# ──────────────────────────────────────────────────────────────
# RME Engineering Intelligence Platform — environment
# Copy this file to `.env.local` and fill in your keys.
# The dev server runs without these (demo mode); auth + AI
# require them to be set.
# ──────────────────────────────────────────────────────────────

# Supabase ------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings (Anthropic recommends Voyage AI for RAG) ----------
# Used to embed document chunks + queries for pgvector search.
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3
EMBED_DIMENSIONS=1024

# App ----------------------------------------------------------
NEXT_PUBLIC_APP_NAME=RME Engineering Intelligence
NEXT_PUBLIC_DEMO_MODE=true
